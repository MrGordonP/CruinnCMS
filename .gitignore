# Platform credentials — generated by the install wizard, never commit
config/CruinnCMS.php
CruinnCMS/config/CruinnCMS.php

# Local dev overrides
config/config.local.php
CruinnCMS/config/config.local.php

# Active instance pointer (dev/runtime state)
instance/.active
CruinnCMS/instance/.active

# Per-instance credentials generated at provisioning
instance/*/config.php
CruinnCMS/instance/*/config.php

# Per-instance data (mail archives, forum backups, etc.)
CruinnCMS/instance/*/

# User uploads and generated storage
public/storage/*
public/uploads/*
!public/storage/.gitkeep
!public/uploads/.gitkeep
public_html/storage/*
public_html/uploads/*
!public_html/storage/.gitkeep
!public_html/uploads/.gitkeep

# Runtime logs
server_err.log
*.log

# Composer dependencies (install via composer install)
vendor/
CruinnCMS/vendor/

# Release packages
release/

# OS
.DS_Store
Thumbs.db
CruinnCMS.zip
public_html/public.zip
